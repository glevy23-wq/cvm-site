{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/empresa/:path*",
      "destination": "/api/empresa"
    },
    {
      "source": "/empresa",
      "destination": "/api/empresa"
    },
    {
      "source": "/aqal",
      "destination": "/api/aqal"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/memory",
      "destination": "/api/memory"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=60"
        }
      ]
    }
  ],
  "env": {
    "SUPABASE_URL": "https://emumlldqewikrvbdfesd.supabase.co"
  }
}