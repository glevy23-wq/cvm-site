{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "functions": {
    "api/empresa.ts": {
      "runtime": "edge"
    },
    "api/aqal.ts": {
      "runtime": "edge"
    }
  },
  "routes": [
    { "src": "/api/empresa", "dest": "/api/empresa.ts" },
    { "src": "/api/aqal", "dest": "/api/aqal.ts" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
